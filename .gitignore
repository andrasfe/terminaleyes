*.log

# Password files — never commit
*.pass
*.password

# Playwright MCP server logs
.playwright-mcp/

# ML artefacts — adapters, intermediate datasets, checkpoints
# Ignore everything under data/ml/ EXCEPT the tiny open-loop pointer-
# acceleration model (~20 KB) and its training dataset — those are
# load-bearing for fast cursor homing on Ubuntu and we want a fresh
# clone to work without retraining.
data/ml/*
!data/ml/checkpoints/
data/ml/checkpoints/*
!data/ml/checkpoints/pointer_accel-*/
!data/ml/pointer_accel/
*.safetensors
