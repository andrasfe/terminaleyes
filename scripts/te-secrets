#!/usr/bin/env bash
# te-secrets — encrypted name/value store for terminaleyes, with the
# master passphrase pinned in the macOS Keychain so add/remove/lookup
# never prompts you for it after the one-time init.
#
# Storage:
#   * Master passphrase — macOS Keychain (AES-encrypted at rest by the
#     OS, unlocked at login). Service "terminaleyes-vault", account
#     equal to the running user.
#   * Entries (name/value pairs) — the existing terminaleyes vault file
#     at ~/.local/share/terminaleyes/vault.bin (AES-256-GCM, scrypt KDF
#     N=2**15, file mode 0600). The master from Keychain unlocks it at
#     runtime via the TERMINALEYES_VAULT_PASSPHRASE env var, which the
#     vault Python class already supports natively — the env var only
#     lives inside the spawned child process and is never written to
#     disk.
#
# Usage:
#   te-secrets init                 — set/replace the Keychain master
#   te-secrets add  <name>          — add or replace an entry value
#   te-secrets get  <name>          — print one entry's value to stdout
#   te-secrets rm   <name>          — remove an entry
#   te-secrets ls                   — list entry names (no values)
#   te-secrets status               — vault file + Keychain status
#   te-secrets run  "<intent>..."   — `terminaleyes do --vault ...`
#                                     with the master injected
#   te-secrets exec <cmd...>        — run any command with the master
#                                     injected as env (advanced)
#
# Examples:
#   te-secrets init                       # one-time
#   te-secrets add desktop                # prompts via getpass
#   te-secrets ls
#   te-secrets run desktop "unlock the screen"

set -euo pipefail

KEYCHAIN_SERVICE="terminaleyes-vault"
KEYCHAIN_ACCOUNT="${USER:?USER unset}"
PROG="$(basename "$0")"

die() { printf '%s: %s\n' "$PROG" "$*" >&2; exit 1; }

require_macos() {
  [[ "$(uname -s)" == "Darwin" ]] || die \
    "this wrapper uses macOS Keychain ('security' CLI). On Linux, store \
the master in libsecret/seahorse and export TERMINALEYES_VAULT_PASSPHRASE \
from there instead."
}

require_terminaleyes() {
  command -v terminaleyes >/dev/null 2>&1 || die \
    "terminaleyes CLI not on PATH. Activate the venv or 'pip install -e .'."
}

fetch_master() {
  # Print master to stdout. Fails if not yet initialised.
  local out
  if ! out="$(security find-generic-password \
              -s "$KEYCHAIN_SERVICE" -a "$KEYCHAIN_ACCOUNT" -w 2>/dev/null)"; then
    die "master passphrase not in Keychain — run: $PROG init"
  fi
  printf '%s' "$out"
}

cmd_init() {
  require_macos
  # -U upserts (replace if exists). -w with no value triggers an
  # interactive password prompt that doesn't echo.
  echo "Setting master passphrase in macOS Keychain (service='$KEYCHAIN_SERVICE')."
  echo "  This passphrase encrypts the vault file at rest. Pick something strong."
  security add-generic-password \
    -U -s "$KEYCHAIN_SERVICE" -a "$KEYCHAIN_ACCOUNT" -w
  echo "  ✓ stored in Keychain (no plaintext on disk)."
}

with_master() {
  # Runs the rest of the args with TERMINALEYES_VAULT_PASSPHRASE set
  # from the Keychain only for the lifetime of that child process.
  require_macos
  require_terminaleyes
  TERMINALEYES_VAULT_PASSPHRASE="$(fetch_master)" "$@"
}

cmd_add()    { with_master terminaleyes vault add    "$@"; }
cmd_get()    { with_master terminaleyes vault get    "$@"; }
cmd_rm()     { with_master terminaleyes vault remove "$@"; }
cmd_ls()     { with_master terminaleyes vault list   "$@"; }
cmd_status() { with_master terminaleyes vault status "$@"; }

cmd_run() {
  [[ $# -ge 2 ]] || die "usage: $PROG run <entry-name> \"<intent>\""
  local name="$1"; shift
  with_master terminaleyes do --vault "$name" "$@"
}

cmd_exec() {
  [[ $# -ge 1 ]] || die "usage: $PROG exec <command> [args...]"
  with_master "$@"
}

cmd_help() {
  sed -n '2,28p' "$0" | sed 's/^# \{0,1\}//'
}

main() {
  [[ $# -ge 1 ]] || { cmd_help; exit 2; }
  local sub="$1"; shift
  case "$sub" in
    init)            cmd_init    "$@" ;;
    add)             cmd_add     "$@" ;;
    get)             cmd_get     "$@" ;;
    rm|remove|del)   cmd_rm      "$@" ;;
    ls|list)         cmd_ls      "$@" ;;
    status)          cmd_status  "$@" ;;
    run)             cmd_run     "$@" ;;
    exec)            cmd_exec    "$@" ;;
    -h|--help|help)  cmd_help    ;;
    *)               die "unknown subcommand '$sub'. Try: $PROG help" ;;
  esac
}

main "$@"
